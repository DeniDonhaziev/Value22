# Скопируйте в server/.env (для локального запуска) или задайте в дашборде Render.

# Строка подключения Neon Postgres (обязательно).
# Возьмите в Neon → Dashboard → Connection string (Pooled). Пример:
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require

# Секрет для подписи JWT-токенов (обязательно, любой длинный случайный набор символов).
JWT_SECRET=change-me-to-a-long-random-string

# Окружение
NODE_ENV=production

# Необязательно: если фронт деплоится отдельно — укажите его URL для CORS.
# FRONTEND_URL=https://your-frontend.example.com
